# Exemple de fichier .env — à copier en .env et remplir avec tes vraies clés.
# NE JAMAIS commit le vrai .env (déjà dans .gitignore).

# --- OpenAI ---------------------------------------------------------------
OPENAI_API_KEY=sk-...

# --- Supabase (auth du POST /chat) ----------------------------------------
# On valide les tokens utilisateur en local en ES256, avec la clé publique
# servie par {SUPABASE_URL}/auth/v1/.well-known/jwks.json. Le backend fetch
# le JWKS au démarrage (et toutes les heures) — aucun secret partagé requis.
SUPABASE_URL=https://<project-ref>.supabase.co

# Anon key Supabase. Nécessaire pour appeler la RPC `is_chatbot_unlocked`
# qui implémente la gate "5/5 chapitres terminés OU admin override".
# On passe l'anon key dans le header `apikey` + le JWT user en `Authorization`.
# La RPC s'exécute dans le contexte de l'utilisateur (auth.uid()) donc RLS-safe.
SUPABASE_ANON_KEY=eyJ...

# Désactive la gate (à TRUE seulement en dev local pour tester sans avoir
# fait les 5 chapitres). NE JAMAIS METTRE TRUE EN PROD.
# CHATBOT_GATE_DISABLED=false

# Audience attendue dans le JWT (par défaut "authenticated"). Mettre à
# chaîne vide pour désactiver le check d'audience si besoin.
# SUPABASE_JWT_AUDIENCE=authenticated

# URL du JWKS, surchargeable si Supabase change le path par défaut.
# SUPABASE_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json

# --- CORS (optionnel) -----------------------------------------------------
# Origines autorisées en CSV. Par défaut : dev local + prod Lovable.
# ALLOWED_ORIGINS=http://localhost:5173,https://skill-architect-core.lovable.app

# --- Chroma / modèles (optionnel) -----------------------------------------
# CHROMA_PATH=./chroma_db      # en prod sur Fly : /data/chroma_db (volume)
# COLLECTION_NAME=istqb_knowledge
# CHAT_MODEL=gpt-4.1-mini
# EMBED_MODEL=text-embedding-3-small
